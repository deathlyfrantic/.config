auto-reload yes

unbind-key ^B
unbind-key g
unbind-key G

bind-key $ reload-all
bind-key j down
bind-key k up
bind-key ^F pagedown
bind-key ^B pageup
bind-key g home
bind-key G end
browser google-chrome-stable

# zenburn theme from https://gist.github.com/ivoarch/8256644
color background color188 color237
color info color223 color234
color article color188 color237
color listnormal color188 color237
color listfocus color108 color234
color listnormal_unread color108 color237
color listfocus_unread color108 color234

highlight article "^(Feed|Title|Author|Link|Date|Podcast Download URL):.*" color108 color237 bold
